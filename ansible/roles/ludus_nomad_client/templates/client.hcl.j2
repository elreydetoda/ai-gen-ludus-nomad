datacenter = "{{ nomad_datacenter }}"
region     = "{{ nomad_region }}"
data_dir   = "{{ nomad_data_dir }}"
bind_addr  = "0.0.0.0"

advertise {
  http = "{{ ansible_host | default(ansible_default_ipv4.address) }}:4646"
  rpc  = "{{ ansible_host | default(ansible_default_ipv4.address) }}:4647"
  serf = "{{ ansible_host | default(ansible_default_ipv4.address) }}:4648"
}

client {
  enabled = true
  servers = [{% for host in groups["nomad_servers"] %}"{{ hostvars[host].ansible_host | default(hostvars[host].ansible_default_ipv4.address) }}:4647"{% if not loop.last %}, {% endif %}{% endfor %}]

  options = {
    "driver.raw_exec.enable" = "0"
  }
}

plugin "docker" {
  config {
    allow_privileged = false
    gc {
      image       = true
      image_delay = "3m"
      container   = true
      dangling_containers {
        enabled = true
      }
    }
  }
}

acl {
  enabled = true
}

tls {
  http                   = true
  rpc                    = true
  verify_server_hostname = true
  verify_https_client    = true
  ca_file                = "{{ nomad_tls_dir }}/nomad-ca.pem"
  cert_file              = "{{ nomad_tls_dir }}/nomad-agent.pem"
  key_file               = "{{ nomad_tls_dir }}/nomad-agent-key.pem"
}
